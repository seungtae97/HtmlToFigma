{
    "manifest_version": 3,
    "name": "HTML to Figma Converter",
    "version": "2.2.0",
    "description": "Convert current webpage to Figma design with full CSS fidelity",
    "permissions": [
        "activeTab",
        "scripting",
        "debugger",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "src/popup/index.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}