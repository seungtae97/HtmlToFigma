{
    "compilerOptions": {
        "target": "es6",
        "lib": [
            "es2017",
            "dom"
        ],
        "strict": true,
        "moduleResolution": "node",
        "jsx": "react-jsx",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "typeRoots": [
            "./node_modules/@figma",
            "./node_modules/@types"
        ]
    },
    "include": [
        "src/**/*",
        "index.html",
        "vite.config.js"
    ]
}